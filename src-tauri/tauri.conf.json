{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VectorGCS",
  "version": "0.1.0-alpha.4",
  "identifier": "com.vector.gcs",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vector GCS",
        "width": 1200,
        "height": 800,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://SurajPawar661.github.io/configurator/updates/{{target}}-{{arch}}.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDNTNCREU1NUIzNTc2RDAKUldUUWRqVmI1YjFUUEFSLzNURUowRmFWWWhuVVBucFQ4QjRsMmZRRmRob2VENThEY2E4TzhVcG8K"
    }
  }
}